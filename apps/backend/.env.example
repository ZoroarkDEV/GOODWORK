# GOODWORK Backend Environment Variables

# Local PostgreSQL connection string (Docker default)
DATABASE_URL="postgresql://goodwork_admin:goodwork_secure_pass@127.0.0.1:5432/goodwork_db"

# Supabase Configurations (Local or Cloud production)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-key

# JWT & Authentication Secret (Fallback)
JWT_SECRET=goodwork-super-secret-jwt-token-key-change-in-production
